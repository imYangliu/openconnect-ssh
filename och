#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

if [[ -x "$SCRIPT_DIR/rust-cli/target/debug/och" ]]; then
  exec "$SCRIPT_DIR/rust-cli/target/debug/och" "$@"
fi

if command -v cargo >/dev/null 2>&1; then
  exec cargo run --quiet --manifest-path "$SCRIPT_DIR/rust-cli/Cargo.toml" -- "$@"
fi

echo "Error: cannot find Rust OCH binary; run: cargo build --manifest-path $SCRIPT_DIR/rust-cli/Cargo.toml" >&2
exit 1
