# Copy this file to .env for local overrides, or pass it explicitly with
# ENV_FILE=/path/to/private.env. The main OCH config is config.toml.

VPN_HOST=vpn.example.com
VPN_USER=your_vpn_username
# VPN_AUTHGROUP=your_auth_group

# macOS can usually leave VPN_ROUTES unset and use OpenConnect's built-in
# vpnc-script. Linux split-tunnel mode normally needs VPN_ROUTES unless you set
# VPN_SCRIPT_CMD explicitly.
# VPN_ROUTES="x.x.x.x/yy a.b.c.d/zz"
# VPN_SCRIPT_CMD=/usr/local/bin/vpn-slice x.x.x.x/yy a.b.c.d/zz
# MACOS_EXTRA_ROUTES="10.0.0.0/8 192.168.0.0/16"

DEFAULT_HOST=och-target
TARGET_HOST=your-campus-host.example
TARGET_PORT=22
TARGET_SSH_USER=your-ssh-user

# Optional reverse proxy mapping used by `och --proxy`.
PROXY_LOCAL_HOST=127.0.0.1
PROXY_LOCAL_PORT=7890
PROXY_REMOTE_PORT=7890

# Recommended for CLI-only use: keep the VPN password in this private env file,
# not in config.toml. Do not commit the real value.
# VPN_PASSWORD=your_vpn_password
