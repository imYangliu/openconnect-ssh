#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

if [[ -z "${ECNU_SSH_LIBEXEC_DIR:-}" ]]; then
  if [[ -x "$SCRIPT_DIR/src/ecnu-ssh.sh" ]]; then
    ECNU_SSH_LIBEXEC_DIR="$SCRIPT_DIR/src"
  elif [[ -x "$SCRIPT_DIR/../libexec/ecnu-ssh/ecnu-ssh.sh" ]]; then
    ECNU_SSH_LIBEXEC_DIR="$SCRIPT_DIR/../libexec/ecnu-ssh"
  else
    echo "Error: cannot find ecnu-ssh implementation" >&2
    exit 1
  fi
fi

if [[ -z "${PROJECT_ENV_FILE:-}" && -r "$SCRIPT_DIR/.env" ]]; then
  export PROJECT_ENV_FILE="$SCRIPT_DIR/.env"
fi

export ECNU_SSH_COMMAND_NAME="$(basename "$0")"

if [[ -z "${CONNECT_SCRIPT:-}" ]]; then
  export CONNECT_SCRIPT="$ECNU_SSH_LIBEXEC_DIR/connect-campus-server.sh"
fi

exec "$ECNU_SSH_LIBEXEC_DIR/ecnu-ssh.sh" "$@"
