# Copy this file to ~/.config/ecnu-ssh.env if you want `ecnu-ssh` to work
# without passing a host each time.

# By default, ecnu-ssh finds connect-campus-server.sh from PATH first.
# CONNECT_SCRIPT=/opt/homebrew/bin/connect-campus-server.sh
VPN_SERVICE=ecnu-openconnect.service
DEFAULT_HOST=ecnu-target

# Optional proxy reverse forwarding defaults used by `ecnu-ssh --proxy`.
PROXY_LOCAL_HOST=127.0.0.1
PROXY_LOCAL_PORT=7890
PROXY_REMOTE_PORT=7890
