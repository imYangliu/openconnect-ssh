# Copy this file to ~/.config/och/och-vpn.env
# or /etc/och/och-vpn.env and fill in your own values.

VPN_HOST=vpn.example.com
VPN_USER=your_vpn_username

# Optional for installations that require an auth group / realm selection.
# VPN_AUTHGROUP=your_auth_group

# Optional on macOS when using OpenConnect's built-in vpnc-script.
# Required on Linux unless VPN_SCRIPT_CMD is set.
# VPN_ROUTES="x.x.x.x/yy a.b.c.d/zz"
# MACOS_EXTRA_ROUTES="10.0.0.0/8 192.168.0.0/16"

# Optional target used by `och-vpn verify` and by `och`.
TARGET_HOST=your-campus-host.example
TARGET_PORT=22
TARGET_SSH_USER=your-ssh-user

# Optional: put your password here only if you accept the security trade-off.
# VPN_PASSWORD=

# Optional overrides.
# OPENCONNECT_BIN=/usr/sbin/openconnect
# VPN_SCRIPT_CMD=/usr/local/bin/vpn-slice x.x.x.x/yy a.b.c.d/zz
# macOS Homebrew OpenConnect already has a default vpnc-script at:
# /opt/homebrew/etc/vpnc/vpnc-script
# PID_FILE=/run/och-openconnect.pid
# LOG_FILE=/var/log/och-openconnect.log
