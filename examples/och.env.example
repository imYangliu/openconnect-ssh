# Copy this file to ~/.config/och/och.env if you want `och` to work
# without passing a host each time.

# By default, och finds och-vpn from PATH first.
# CONNECT_SCRIPT=/opt/homebrew/bin/och-vpn
VPN_SERVICE=och-openconnect.service
DEFAULT_HOST=och-target

# Optional proxy reverse forwarding defaults used by `och --proxy`.
PROXY_LOCAL_HOST=127.0.0.1
PROXY_LOCAL_PORT=7890
PROXY_REMOTE_PORT=7890
