[Unit]
Description=Keep OpenConnect split-tunnel access alive
After=network-online.target ecnu-openconnect.service
Wants=network-online.target

[Service]
Type=oneshot
Environment=VPN_SERVICE=ecnu-openconnect.service
Environment=CONNECT_SCRIPT=/usr/local/bin/connect-campus-server.sh
Environment=FAIL_THRESHOLD=2
Environment=STATE_DIR=/run/ecnu-openconnect-keepalive
ExecStart=/usr/local/bin/ecnu-openconnect-keepalive.sh
